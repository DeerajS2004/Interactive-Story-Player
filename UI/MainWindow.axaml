<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="InteractiveStoryPlayer.UI.MainWindow"
        Title="Story Player"
        Width="1200"
        Height="800"
        MinWidth="1000"
        MinHeight="700"
        Background="#121212">
    <Window.Styles>
        <!-- Dark Theme Button Styles with Hover and Pressed Effects -->
        <Style Selector="Button">
            <Setter Property="Background" Value="#264d37"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.15"/>
                </Transitions>
            </Setter>
        </Style>
        
        <!-- Button Hover Effect -->
        <Style Selector="Button:pointerover">
            <Setter Property="Background" Value="#3a7051"/>
        </Style>
        
        <!-- Button Pressed Effect -->
        <Style Selector="Button:pressed">
            <Setter Property="Background" Value="#1c392a"/>
        </Style>
        
        <!-- Load Button Styling -->
        <Style Selector="Button.load">
            <Setter Property="Background" Value="#4d3826"/>
        </Style>
        <Style Selector="Button.load:pointerover">
            <Setter Property="Background" Value="#70513a"/>
        </Style>
        <Style Selector="Button.load:pressed">
            <Setter Property="Background" Value="#39291c"/>
        </Style>
        
        <!-- Exit Button Styling -->
        <Style Selector="Button.exit">
            <Setter Property="Background" Value="#4d2626"/>
        </Style>
        <Style Selector="Button.exit:pointerover">
            <Setter Property="Background" Value="#703a3a"/>
        </Style>
        <Style Selector="Button.exit:pressed">
            <Setter Property="Background" Value="#391c1c"/>
        </Style>
        
        <!-- Action Button Styling -->
        <Style Selector="Button.action">
            <Setter Property="Background" Value="#264d4d"/>
            <Setter Property="FontSize" Value="14"/>
        </Style>
        <Style Selector="Button.action:pointerover">
            <Setter Property="Background" Value="#3a7070"/>
        </Style>
        <Style Selector="Button.action:pressed">
            <Setter Property="Background" Value="#1c3939"/>
        </Style>
        
        <!-- Save Button Styling -->
        <Style Selector="Button.save">
            <Setter Property="Background" Value="#264d26"/>
        </Style>
        <Style Selector="Button.save:pointerover">
            <Setter Property="Background" Value="#3a703a"/>
        </Style>
        <Style Selector="Button.save:pressed">
            <Setter Property="Background" Value="#1c391c"/>
        </Style>
        
        <!-- Choice Button Styling -->
        <Style Selector="Button.choice">
            <Setter Property="Background" Value="#374d26"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Height" Value="55"/>
            <Setter Property="Margin" Value="0,5"/>
        </Style>
        <Style Selector="Button.choice:pointerover">
            <Setter Property="Background" Value="#51703a"/>
        </Style>
        <Style Selector="Button.choice:pressed">
            <Setter Property="Background" Value="#29391c"/>
        </Style>
    </Window.Styles>
    
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Main Menu Screen -->
        <Grid Name="MainMenuGrid" Grid.Row="0" IsVisible="True">
            <Image Name="BackgroundImage" Stretch="UniformToFill" Opacity="0.4"/>
            <Border Background="#00000080" />
            
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="40">
                <TextBlock Name="TitleText" Text="The Enchanted Forest" FontSize="56" FontWeight="Bold" 
                           Foreground="White" TextAlignment="Center">
                    <TextBlock.Effect>
                        <DropShadowEffect Color="#000000" OffsetX="2" OffsetY="2" BlurRadius="6"/>
                    </TextBlock.Effect>
                </TextBlock>
                
                <StackPanel Spacing="20" Width="300">
                    <Button Name="StartNewStoryButton" Content="Start New Story" 
                        Height="60" FontSize="20" CornerRadius="8"
                        HorizontalAlignment="Stretch" Click="OnStartNewStoryClick"/>

                    
                    <Button Name="LoadProgressButton" Content="Load Progress" 
                            Classes="load" Height="60" FontSize="20" CornerRadius="8"
                            HorizontalAlignment="Stretch" Click="OnLoadProgressClick"/>
                    
                    <Button Name="ExitGameButton" Content="Exit" 
                            Classes="exit" Height="60" FontSize="20" CornerRadius="8"
                            HorizontalAlignment="Stretch" Click="OnExitClick"/>
                </StackPanel>
            </StackPanel>
        </Grid>

        <!-- Story Playing Screen -->
        <Grid Name="StoryPlayerGrid" Grid.Row="0" IsVisible="False" Background="#121212">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="2*"/>
                <ColumnDefinition Width="3*"/>
            </Grid.ColumnDefinitions>

            <!-- Left Panel - Multiple Images -->
            <ScrollViewer Grid.Column="0" Margin="40,40,20,40" 
                          VerticalScrollBarVisibility="Auto" 
                          HorizontalScrollBarVisibility="Disabled">
                <StackPanel Name="ImagesPanel" Spacing="15" 
                            HorizontalAlignment="Center">
                    <!-- Multiple images will be added here dynamically -->
                </StackPanel>
            </ScrollViewer>

            <!-- Right Panel - Story Content -->
            <StackPanel Grid.Column="1" Margin="20,40,40,40" 
                        VerticalAlignment="Center" Spacing="25">
                
                <!-- Story Text -->
                <Border Background="#1e1e1e" CornerRadius="12" Padding="25">
                    <ScrollViewer MaxHeight="350" VerticalScrollBarVisibility="Auto">
                        <TextBlock Name="SceneText" 
                                   Text="" 
                                   TextWrapping="Wrap" FontSize="24" FontWeight="Medium" 
                                   FontFamily="Georgia, serif" Foreground="#e0e0e0" 
                                   LineHeight="32"/>
                    </ScrollViewer>
                </Border>

                <!-- Choice Buttons -->
                <StackPanel Name="ChoicesPanel" Spacing="12">
                    <!-- Dynamic buttons will be added here -->
                </StackPanel>
                
                <!-- Action Buttons -->
                <StackPanel Orientation="Horizontal" Spacing="15" 
                            HorizontalAlignment="Center" Margin="0,20,0,0">
                    <Button Name="BackToMenuButton" Content="🏠 Main Menu" 
                            Classes="action" Height="45" Padding="15,0" CornerRadius="6"
                            Click="OnBackToMenuClick"/>
                    
                    <Button Name="SaveProgressButton" Content="💾 Save" 
                            Classes="save" Height="45" Padding="15,0" CornerRadius="6"
                            Click="OnSaveProgressClick"/>
                </StackPanel>
                
            </StackPanel>
        </Grid>

        <!-- Status Bar -->
        <Border VerticalAlignment="Bottom" Background="#1e1e1e" Padding="10,6">
            <TextBlock Name="StatusText" FontSize="12" Foreground="#b0b0b0" Text="Ready"/>
        </Border>
    </Grid>
</Window>
