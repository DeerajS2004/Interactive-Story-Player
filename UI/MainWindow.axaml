<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="InteractiveStoryPlayer.UI.MainWindow"
        Title="Interactive Story Player"
        Width="1280"
        Height="800"
        MinWidth="1024"
        MinHeight="650"
        Background="#0c0c0e">

    <Window.Styles>

        <!-- ── Base Button Reset ── -->
        <Style Selector="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#d0d0d8"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Transitions">
                <Transitions>
                    <BrushTransition Property="Background" Duration="0:0:0.12"/>
                    <BrushTransition Property="BorderBrush" Duration="0:0:0.12"/>
                </Transitions>
            </Setter>
        </Style>

        <!-- ── Main Menu Buttons ── -->
        <Style Selector="Button.menu-btn">
            <Setter Property="Height" Value="54"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#131318"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#252530"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Foreground" Value="#9090a0"/>
        </Style>
        <Style Selector="Button.menu-btn:pointerover">
            <Setter Property="Background" Value="#1c1c24"/>
            <Setter Property="BorderBrush" Value="#c9a84c"/>
            <Setter Property="Foreground" Value="#c9a84c"/>
        </Style>
        <Style Selector="Button.menu-btn:pressed">
            <Setter Property="Background" Value="#0e0e14"/>
        </Style>

        <Style Selector="Button.menu-start">
            <Setter Property="Background" Value="#141e14"/>
            <Setter Property="BorderBrush" Value="#2a3e2a"/>
            <Setter Property="Foreground" Value="#7aaa7a"/>
        </Style>
        <Style Selector="Button.menu-start:pointerover">
            <Setter Property="Background" Value="#1a281a"/>
            <Setter Property="BorderBrush" Value="#c9a84c"/>
            <Setter Property="Foreground" Value="#c9a84c"/>
        </Style>

        <Style Selector="Button.menu-exit">
            <Setter Property="Background" Value="#180f0f"/>
            <Setter Property="BorderBrush" Value="#301818"/>
            <Setter Property="Foreground" Value="#885050"/>
        </Style>
        <Style Selector="Button.menu-exit:pointerover">
            <Setter Property="Background" Value="#201212"/>
            <Setter Property="BorderBrush" Value="#c9a84c"/>
            <Setter Property="Foreground" Value="#c9a84c"/>
        </Style>

        <!-- ── Top Bar Buttons ── -->
        <Style Selector="Button.bar-btn">
            <Setter Property="Height" Value="30"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="Padding" Value="14,0"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#202028"/>
            <Setter Property="CornerRadius" Value="4"/>
            <Setter Property="Foreground" Value="#60607a"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.bar-btn:pointerover">
            <Setter Property="Background" Value="#18181e"/>
            <Setter Property="BorderBrush" Value="#c9a84c"/>
            <Setter Property="Foreground" Value="#c9a84c"/>
        </Style>
        <Style Selector="Button.bar-btn.save">
            <Setter Property="BorderBrush" Value="#1a2e1a"/>
            <Setter Property="Foreground" Value="#4a7a4a"/>
        </Style>
        <Style Selector="Button.bar-btn.save:pointerover">
            <Setter Property="Background" Value="#0e180e"/>
            <Setter Property="BorderBrush" Value="#c9a84c"/>
            <Setter Property="Foreground" Value="#c9a84c"/>
        </Style>

        <!-- ── Font Size Buttons ── -->
        <Style Selector="Button.font-btn">
            <Setter Property="Width" Value="28"/>
            <Setter Property="Height" Value="24"/>
            <Setter Property="FontSize" Value="11"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1e1e2a"/>
            <Setter Property="CornerRadius" Value="3"/>
            <Setter Property="Foreground" Value="#50506a"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="0"/>
        </Style>
        <Style Selector="Button.font-btn:pointerover">
            <Setter Property="Background" Value="#16161e"/>
            <Setter Property="BorderBrush" Value="#c9a84c"/>
            <Setter Property="Foreground" Value="#c9a84c"/>
        </Style>

        <!-- ── Choice Buttons ── -->
        <Style Selector="Button.choice">
            <Setter Property="MinHeight" Value="48"/>
            <Setter Property="FontSize" Value="14"/>
            <Setter Property="HorizontalContentAlignment" Value="Left"/>
            <Setter Property="Padding" Value="18,10"/>
            <Setter Property="Background" Value="#0f0f14"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#1c1c28"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Foreground" Value="#8080a0"/>
            <Setter Property="FontWeight" Value="Normal"/>
        </Style>
        <Style Selector="Button.choice:pointerover">
            <Setter Property="Background" Value="#141420"/>
            <Setter Property="BorderBrush" Value="#c9a84c"/>
            <Setter Property="Foreground" Value="#e0e0f0"/>
        </Style>
        <Style Selector="Button.choice:pressed">
            <Setter Property="Background" Value="#0a0a10"/>
        </Style>

        <!-- ── Restart Button ── -->
        <Style Selector="Button.restart">
            <Setter Property="Height" Value="46"/>
            <Setter Property="FontSize" Value="13"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Background" Value="#14141c"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="BorderBrush" Value="#c9a84c50"/>
            <Setter Property="CornerRadius" Value="5"/>
            <Setter Property="Foreground" Value="#c9a84c"/>
        </Style>
        <Style Selector="Button.restart:pointerover">
            <Setter Property="Background" Value="#1c1c26"/>
            <Setter Property="BorderBrush" Value="#c9a84c"/>
        </Style>

    </Window.Styles>

    <Grid>

        <!-- ══════════════════════════════════════════
             MAIN MENU
        ══════════════════════════════════════════ -->
        <Grid Name="MainMenuGrid" IsVisible="True">

            <Border>
                <Border.Background>
                    <LinearGradientBrush StartPoint="0%,0%" EndPoint="100%,100%">
                        <GradientStop Color="#0c0c0e" Offset="0"/>
                        <GradientStop Color="#0d0f16" Offset="0.6"/>
                        <GradientStop Color="#0a0c0e" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Vignettes -->
            <Border VerticalAlignment="Top" Height="180">
                <Border.Background>
                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                        <GradientStop Color="#30000000" Offset="0"/>
                        <GradientStop Color="#00000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>
            <Border VerticalAlignment="Bottom" Height="120">
                <Border.Background>
                    <LinearGradientBrush StartPoint="50%,0%" EndPoint="50%,100%">
                        <GradientStop Color="#00000000" Offset="0"/>
                        <GradientStop Color="#30000000" Offset="1"/>
                    </LinearGradientBrush>
                </Border.Background>
            </Border>

            <!-- Center card -->
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
                    Width="360"
                    Background="#0f0f14"
                    BorderThickness="1"
                    BorderBrush="#1e1e28"
                    CornerRadius="6"
                    BoxShadow="0 8 60 0 #000000"
                    Padding="40,44">
                <StackPanel Spacing="0">

                    <TextBlock Text="INTERACTIVE"
                               FontSize="10" FontWeight="Light"
                               Foreground="#c9a84c" TextAlignment="Center"
                               LetterSpacing="4" Opacity="0.85"/>

                    <TextBlock Name="MenuTitleText"
                               Text="STORY PLAYER"
                               FontSize="34" FontWeight="Bold"
                               Foreground="#e8e8f0" TextAlignment="Center"
                               Margin="0,8,0,0">
                        <TextBlock.Effect>
                            <DropShadowEffect Color="#000000" OffsetX="0" OffsetY="2"
                                             BlurRadius="16" Opacity="0.9"/>
                        </TextBlock.Effect>
                    </TextBlock>

                    <TextBlock Text="a branching narrative engine"
                               FontSize="11" Foreground="#3a3a4a"
                               TextAlignment="Center" Margin="0,6,0,0"/>

                    <!-- Divider with diamond -->
                    <Grid Height="20" Margin="0,28,0,28">
                        <Border Height="1" VerticalAlignment="Center" Background="#1e1e28"/>
                        <Border Width="5" Height="5" CornerRadius="1"
                                RenderTransform="rotate(45deg)"
                                HorizontalAlignment="Center" VerticalAlignment="Center"
                                Background="#c9a84c"/>
                    </Grid>

                    <StackPanel Spacing="8">
                        <Button Name="StartNewStoryButton"
                                Content="▶  NEW GAME"
                                Classes="menu-btn menu-start"
                                HorizontalAlignment="Stretch"
                                Click="OnStartNewStoryClick"/>

                        <Button Name="LoadProgressButton"
                                Content="◎  CONTINUE"
                                Classes="menu-btn"
                                HorizontalAlignment="Stretch"
                                Click="OnLoadProgressClick"/>

                        <Button Name="ExitGameButton"
                                Content="✕  EXIT"
                                Classes="menu-btn menu-exit"
                                HorizontalAlignment="Stretch"
                                Margin="0,10,0,0"
                                Click="OnExitClick"/>
                    </StackPanel>

                    <TextBlock Text="v1.0"
                               FontSize="10" Foreground="#222230"
                               TextAlignment="Center" Margin="0,28,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

        <!-- ══════════════════════════════════════════
             STORY PLAYER
        ══════════════════════════════════════════ -->
        <Grid Name="StoryPlayerGrid" IsVisible="False" Background="#0c0c0e">
            <Grid.RowDefinitions>
                <RowDefinition Height="44"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="24"/>
            </Grid.RowDefinitions>

            <!-- ── Top Bar ── -->
            <Border Grid.Row="0"
                    Background="#09090c"
                    BorderThickness="0,0,0,1"
                    BorderBrush="#141420">
                <Grid Margin="14,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <!-- Left: back button -->
                    <Button Grid.Column="0"
                            Name="BackToMenuButton"
                            Content="← Menu"
                            Classes="bar-btn"
                            VerticalAlignment="Center"
                            Click="OnBackToMenuClick"/>

                    <!-- Centre: title + scene id -->
                    <StackPanel Grid.Column="1"
                                VerticalAlignment="Center"
                                HorizontalAlignment="Center"
                                Spacing="1">
                        <TextBlock Name="TopBarTitle"
                                   Text="Story Player"
                                   FontSize="13" FontWeight="SemiBold"
                                   Foreground="#b0b0c0" TextAlignment="Center"/>
                        <TextBlock Name="SceneLabel"
                                   Text=""
                                   FontSize="9" Foreground="#2c2c3c"
                                   TextAlignment="Center" LetterSpacing="1.5"/>
                    </StackPanel>

                    <!-- Right: save button -->
                    <Button Grid.Column="2"
                            Name="SaveProgressButton"
                            Content="💾  Save"
                            Classes="bar-btn save"
                            VerticalAlignment="Center"
                            Click="OnSaveProgressClick"/>
                </Grid>
            </Border>

            <!-- ── Main Content — layout reconfigured dynamically in code ── -->
            <Grid Name="ContentGrid" Grid.Row="1"/>

            <!-- ── Status Bar ── -->
            <Border Grid.Row="2"
                    Background="#070708"
                    BorderThickness="0,1,0,0"
                    BorderBrush="#101018"
                    Padding="14,0">
                <TextBlock Name="StatusText"
                           FontSize="9"
                           Foreground="#202030"
                           LetterSpacing="0.5"
                           VerticalAlignment="Center"
                           Text="Ready"/>
            </Border>
        </Grid>

    </Grid>
</Window>
